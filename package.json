{
  "name": "veripatch",
  "version": "0.0.0",
  "description": "Verified remediation for npm vulnerabilities: sandbox-apply fixes, prove elimination, prove safety, emit evidence reports.",
  "keywords": [
    "security",
    "vulnerabilities",
    "npm-audit",
    "remediation",
    "dependencies",
    "cve",
    "osv",
    "supply-chain"
  ],
  "homepage": "https://github.com/amarjaleelbanbhan/VeriPatch#readme",
  "bugs": {
    "url": "https://github.com/amarjaleelbanbhan/VeriPatch/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amarjaleelbanbhan/VeriPatch.git"
  },
  "license": "Apache-2.0",
  "author": "Amar Jaleel Banbhan",
  "type": "module",
  "bin": {
    "veripatch": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^26.1.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "fast-check": "^4.8.0",
    "msw": "^2.14.6",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "commander": "^15.0.0",
    "dockerode": "^5.0.1",
    "pino": "^10.3.1",
    "semver": "^7.8.5",
    "zod": "^4.4.3"
  }
}
